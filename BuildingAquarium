#Verificar predicado, pq no me dan los resultados por 1
#Revisar indices
t = int(input()) #repeticiones
for i in range(t):
    n,h = map(int, input().split()) #columnas y agua
    a = list(map(int, input().split())) #alturas coral   
    lo=0
    hi= max(a) + h + 1
    while(hi-lo>1):
        mid=(lo+hi)//2
        agua=0
        for j in range(n):
            if(a[j]<mid):
                agua+= mid - a[j]   # sum(max(mid - a[j], 0))
        if(agua<=h):
            lo=mid
        else:
            hi=mid
    print(lo)    

