list = ["a", "o", "y", "e", "u", "i"]
string = input().lower()
i=0
while(i<len(string)):
  if(list.__contains__(string[i])):
    string = string.replace(string[i],"", count=1)
  else:
    i=1+i
res=""
k=0
for j in range(len(string)*2):
  if(j%2==0):
    res=res+"."
  else:
    res=res+string[k]
    k=k+1
print(res)