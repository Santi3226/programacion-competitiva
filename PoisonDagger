#Falla por uno en algunos casos

t = int(input()) #repeticiones
for i in range(t):
    n,h = map(int, input().split()) #ataques y vida
    a = list(map(int, input().split())) #cuando ataque   
    lo=0
    hi=h
    while(hi-lo>1):
        mid=(lo+hi)//2
        vida=h
        for j in range(len(a) - 1):          # solo gaps entre ataques consecutivos
            vida -= min(a[j+1] - a[j], mid)
        vida -= mid                           
        if(vida>0):
            lo=mid
        else:
            hi=mid
    print(hi)        

